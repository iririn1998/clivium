{
  "name": "clivium",
  "version": "0.1.0",
  "description": "Terminal hub for coordinating multiple AI CLI agents.",
  "type": "module",
  "bin": {
    "clivium": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "format": "oxfmt --write src",
    "format:check": "oxfmt --check src",
    "test": "vitest run"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "ink": "^7.0.1",
    "node-pty": "^1.1.0",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "typescript": "^5.6.2",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=24.15.0",
    "pnpm": ">=10.33.2"
  },
  "packageManager": "pnpm@10.33.2"
}
